        // ฟังก์ชันสลับการแสดงผลภาษา
        function toggleLanguage() {
            currentLang = currentLang === 'en' ? 'th' : 'en';
            
            const btnEn = document.getElementById('btn-en');
            const btnTh = document.getElementById('btn-th');
            
            if(currentLang === 'en') {
                btnEn.className = 'lang-btn active';
                btnTh.className = 'lang-btn inactive';
            } else {
                btnEn.className = 'lang-btn inactive';
                btnTh.className = 'lang-btn active';
            }

            // แทนที่ข้อความตาม data-i18n attributes
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[currentLang][key]) {
                    el.innerHTML = translations[currentLang][key];
                }
            });

            // Re-render สมการ MathJax ให้ถูกต้องหลังจากเปลี่ยนภาษา
            if(window.MathJax) MathJax.typesetPromise();
            
            // สั่งอัปเดต Simulation และ โจทย์ตัวอย่าง เพื่ออัปเดตคำแปลด้านใน
            updateSimulationMath();
            calculateEx1();
            calculateEx2();
        }

        // ฟังก์ชันดึงค่าแปลภาษา
        function getT(key) {
            return translations[currentLang][key] || key;
        }

        // --- 2. ระบบจำลอง 3 มิติ (Three.js 3D Simulation) ---
        let scene, camera, renderer, objectCube, wireLine, scaleSprite;
        let arrowW, arrowFb, arrowWapp;
        let labelW, labelFb, labelWapp;
        
        let objDensityInput = document.getElementById('obj-density');
        let objLengthInput = document.getElementById('obj-length');
        let fluidDensityInput = document.getElementById('fluid-density');
        
        let targetY = 0;
        let time = 0;
        let isFloating = false;

        // การสร้างฉาก (Scene) และวัตถุตั้งต้น
        function init3D() {
            const container = document.getElementById('canvas-container');
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0xf8fafc); 

            // Camera is pulled back to see the scale and the tank clearly
            camera = new THREE.PerspectiveCamera(40, container.clientWidth / container.clientHeight, 0.1, 100);
            camera.position.set(0, 4, 15); 

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.shadowMap.enabled = true;
            container.appendChild(renderer.domElement);

            const controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.minDistance = 4;
            controls.maxDistance = 25;
            controls.target.set(0, 2.5, 0);

            // Lighting (การจัดแสงสว่าง)
            scene.add(new THREE.AmbientLight(0xffffff, 0.9));
            const dirLight = new THREE.DirectionalLight(0xffffff, 0.7);
            dirLight.position.set(5, 10, 5);
            dirLight.castShadow = true;
            scene.add(dirLight);

            const mainGroup = new THREE.Group();
            
            // 1. ถังใส่น้ำ (Tank)
            const tankGeo = new THREE.CylinderGeometry(1.5, 1.5, 2.5, 32);
            const tankMat = new THREE.MeshPhysicalMaterial({ 
                color: 0xbae6fd, 
                transmission: 0.2, 
                opacity: 0.4, 
                transparent: true, 
                roughness: 0.1, 
                side: THREE.DoubleSide
            });
            const tank = new THREE.Mesh(tankGeo, tankMat);
            tank.position.set(0, 1.25, 0);
            mainGroup.add(tank);

            // เส้นขอบ (Edges) เพื่อให้เห็นขอบถังน้ำชัดเจนขึ้น
            const tankEdges = new THREE.EdgesGeometry(tankGeo);
            const tankLine = new THREE.LineSegments(tankEdges, new THREE.LineBasicMaterial({ color: 0x38bdf8, linewidth: 2 }));
            tank.add(tankLine);

            // 2. ปริมาตรน้ำในถัง (Liquid)
            const waterGeo = new THREE.CylinderGeometry(1.48, 1.48, 2.45, 32);
            const waterMat = new THREE.MeshPhysicalMaterial({ 
                color: 0x0ea5e9, transparent: true, opacity: 0.65 
            });
            const water = new THREE.Mesh(waterGeo, waterMat);
            water.position.set(0, 1.225, 0);
            mainGroup.add(water);

            // 3. วัตถุทรงลูกบาศก์ที่แขวนอยู่ (Object Cube)
            const objGeo = new THREE.BoxGeometry(0.5, 0.5, 0.5);
            const objMat = new THREE.MeshStandardMaterial({ color: 0xf97316, roughness: 0.4 });
            objectCube = new THREE.Mesh(objGeo, objMat);
            objectCube.castShadow = true;
            objectCube.position.set(0, 2.5, 0);
            
            const objEdges = new THREE.EdgesGeometry(objGeo);
            const objLine = new THREE.LineSegments(objEdges, new THREE.LineBasicMaterial({ color: 0x7c2d12 }));
            objectCube.add(objLine);
            
            // --- ใส่เวกเตอร์แรงเข้าไปในวัตถุ (Force Vectors) ---
            // ปรับสีลูกศรให้เข้มขึ้นเล็กน้อย เพื่อให้อ่านง่าย
            arrowW = new THREE.ArrowHelper(new THREE.Vector3(0, -1, 0), new THREE.Vector3(0,0,0), 1, 0xdc2626, 0.2, 0.15);
            arrowFb = new THREE.ArrowHelper(new THREE.Vector3(0, 1, 0), new THREE.Vector3(0,0,0), 1, 0x0284c7, 0.2, 0.15);
            arrowWapp = new THREE.ArrowHelper(new THREE.Vector3(0, 1, 0), new THREE.Vector3(0,0,0), 1, 0xd97706, 0.2, 0.15);
            
            objectCube.add(arrowW);
            objectCube.add(arrowFb);
            objectCube.add(arrowWapp);

            // ป้ายกำกับแรง (Labels for vectors) ส่งค่าสีที่เข้มขึ้นไปแสดงผล
            labelW = createForceLabel("W", "#dc2626");
            labelFb = createForceLabel("Fb", "#0284c7");
            labelWapp = createForceLabel("Wapp", "#d97706");
            
            objectCube.add(labelW);
            objectCube.add(labelFb);
            objectCube.add(labelWapp);

            mainGroup.add(objectCube);

            // 4. โครงสร้างตาชั่งสปริง (Spring Scale Assembly)
            const scaleGeo = new THREE.BoxGeometry(1.2, 0.6, 0.6);
            const scaleMat = new THREE.MeshStandardMaterial({ color: 0x334155 });
            const scaleBase = new THREE.Mesh(scaleGeo, scaleMat);
            scaleBase.position.set(0, 4.5, 0);
            mainGroup.add(scaleBase);

            const hookGeo = new THREE.CylinderGeometry(0.05, 0.05, 0.3);
            const hook = new THREE.Mesh(hookGeo, new THREE.MeshStandardMaterial({ color: 0x1e293b }));
            hook.position.set(0, 4.05, 0);
            mainGroup.add(hook);

            // 5. เส้นลวดเชื่อมระหว่างตาชั่งและวัตถุ (Wire Line)
            const wireMat = new THREE.LineBasicMaterial({ color: 0x1e293b, linewidth: 2 });
            const wireGeo = new THREE.BufferGeometry().setFromPoints([
                new THREE.Vector3(0, 4.05, 0),
                new THREE.Vector3(0, 2.5, 0) 
            ]);
            wireLine = new THREE.Line(wireGeo, wireMat);
            mainGroup.add(wireLine);

            scene.add(mainGroup);

            // 6. หน้าจอแสดงผลตัวเลขน้ำหนักของตาชั่ง (Scale Digital Reading Sprite)
            scaleSprite = createTextSprite("0.00 kg");
            scaleSprite.position.set(0, 5.2, 0); 
            scene.add(scaleSprite);

            // พื้นหลังตาราง (Ground grid)
            const gridHelper = new THREE.GridHelper(15, 15, 0x94a3b8, 0xcbd5e1);
            scene.add(gridHelper);

            window.addEventListener('resize', onWindowResize, false);
            
            // เริ่มต้นการคำนวณและการอนิเมชันครั้งแรก
            updateSimulationMath();
            animate();
        }

        // ฟังก์ชันสร้างป้าย Sprite (ข้อความลอย) สำหรับหน้าจอตาชั่ง
        function createTextSprite(message) {
            const canvas = document.createElement('canvas');
            canvas.width = 512; 
            canvas.height = 160; 
            const context = canvas.getContext('2d');
            
            // LED Screen Background
            context.fillStyle = '#0f172a'; // slate-900
            context.fillRect(0, 0, canvas.width, canvas.height);
            context.strokeStyle = '#475569'; // slate-600
            context.lineWidth = 12;
            context.strokeRect(0, 0, canvas.width, canvas.height);

            // Text Setup
            context.font = 'bold 86px Prompt, sans-serif';
            context.fillStyle = '#22c55e'; // Bright digital green (emerald-500)
            context.textAlign = 'center';
            context.textBaseline = 'middle';
            context.fillText(message, canvas.width / 2, canvas.height / 2 + 5);

            const texture = new THREE.CanvasTexture(canvas);
            const spriteMaterial = new THREE.SpriteMaterial({ map: texture });
            const sprite = new THREE.Sprite(spriteMaterial);
            // Size of the sprite in the 3D scene (Made larger)
            sprite.scale.set(2.0, 0.625, 1); 
            return sprite;
        }

        function updateScaleSpriteText(sprite, message) {
            if(!sprite) return;
            const canvas = sprite.material.map.image;
            const context = canvas.getContext('2d');
            context.fillStyle = '#0f172a';
            context.fillRect(0, 0, canvas.width, canvas.height);
            context.strokeStyle = '#475569';
            context.strokeRect(0, 0, canvas.width, canvas.height);
            context.font = 'bold 86px Prompt, sans-serif';
            context.fillStyle = '#22c55e';
            context.textAlign = 'center';
            context.textBaseline = 'middle';
            context.fillText(message, canvas.width / 2, canvas.height / 2 + 5);
            sprite.material.map.needsUpdate = true;
        }

        // ฟังก์ชันสร้างป้ายกำกับแรง (Force Labels)
        function createForceLabel(text, colorStr) {
            const canvas = document.createElement('canvas');
            // ขยายขนาด Canvas ให้กว้างขึ้นเพื่อป้องกันตัวเลขแหว่ง
            canvas.width = 512;
            canvas.height = 128;
            const context = canvas.getContext('2d');
            
            const texture = new THREE.CanvasTexture(canvas);
            const spriteMat = new THREE.SpriteMaterial({ map: texture, depthTest: false, transparent: true });
            const sprite = new THREE.Sprite(spriteMat);
            // ปรับขนาด Scale ให้เหมาะสมกับความกว้างใหม่
            sprite.scale.set(3.0, 0.75, 1);
            sprite.renderOrder = 999; // ให้อยู่หน้าสุดเสมอ
            
            sprite.userData = { color: colorStr }; // เก็บสีไว้ใช้อัปเดต
            return sprite;
        }

        function updateForceLabel(sprite, text) {
            if(!sprite) return;
            const canvas = sprite.material.map.image;
            const context = canvas.getContext('2d');
            context.clearRect(0, 0, canvas.width, canvas.height);
            
            context.font = 'bold 44px Prompt, sans-serif';
            context.textAlign = 'center';
            context.textBaseline = 'middle';
            
            // หาขนาดความกว้างของข้อความ เพื่อวาดกล่องพื้นหลัง
            const textMetrics = context.measureText(text);
            const textWidth = textMetrics.width;
            const paddingX = 30;
            const paddingY = 20;
            
            const rectW = textWidth + (paddingX * 2);
            const rectH = 44 + (paddingY * 2);
            const rectX = (canvas.width / 2) - (rectW / 2);
            const rectY = (canvas.height / 2) - (rectH / 2);

            // สร้างพื้นหลังสีขาวขอบมน (Pill background) เพื่อให้ตัวอักษรอ่านง่ายเมื่อทับกับน้ำ
            context.fillStyle = 'rgba(255, 255, 255, 0.85)';
            context.beginPath();
            if (context.roundRect) {
                context.roundRect(rectX, rectY, rectW, rectH, 15);
            } else {
                context.rect(rectX, rectY, rectW, rectH);
            }
            context.fill();
            context.lineWidth = 4;
            context.strokeStyle = sprite.userData.color;
            context.stroke();
            
            // วาดตัวหนังสือลงไป
            context.fillStyle = sprite.userData.color;
            context.fillText(text, canvas.width / 2, canvas.height / 2 + 3);
            
            sprite.material.map.needsUpdate = true;
        }

        function onWindowResize() {
            const container = document.getElementById('canvas-container');
            camera.aspect = container.clientWidth / container.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(container.clientWidth, container.clientHeight);
        }

        // คำนวณค่าทางฟิสิกส์ (เปลี่ยนสูตรหรือเพิ่มตัวแปรได้ที่นี่)
        function updateSimulationMath() {
            const rho_obj = parseFloat(objDensityInput.value);
            const rho_fluid = parseFloat(fluidDensityInput.value);
            const L = parseFloat(objLengthInput.value);
            
            document.getElementById('obj-density-val').textContent = rho_obj;
            document.getElementById('fluid-density-val').textContent = rho_fluid;
            document.getElementById('obj-length-val').textContent = L.toFixed(2);

            // คำนวณปริมาตรและมวลของวัตถุ
            const V_obj = Math.pow(L, 3); 
            const M_obj = rho_obj * V_obj; 
            const A_base = L * L; 
            
            let V_sub = 0;
            isFloating = rho_obj <= rho_fluid; // ถ้าน้อยกว่าหรือเท่ากับ แสดงว่าวัตถุลอย
            let scaleReadingMass = 0;
            let h_sub = 0;

            // ตรรกะของฟิสิกส์ เรื่องแรงพยุง
            if (isFloating) {
                V_sub = M_obj / rho_fluid;
                scaleReadingMass = 0; // ลอยน้ำ ไม่ต้องใช้ตาชั่งดึง น้ำหนักเป็น 0
                h_sub = V_sub / A_base; // ความลึกส่วนที่จม
            } else {
                V_sub = V_obj; // จมมิดก้อน
                scaleReadingMass = M_obj - (rho_fluid * V_sub); // มวลที่หักล้างด้วยแรงพยุง (มวลปรากฏ)
                h_sub = L; 
            }

            const displacedMass = rho_fluid * V_sub;
            const Fb = displacedMass * 9.81;

            // --- 3D Scene Updates ---
            if(objectCube) {
                // Resize รูปทรงลูกบาศก์ให้ตรงตามค่า Slider
                objectCube.geometry.dispose();
                objectCube.geometry = new THREE.BoxGeometry(L, L, L);
                
                // สร้างเส้นขอบใหม่
                objectCube.children.forEach(child => { if(child.isLineSegments) objectCube.remove(child); });
                const objEdges = new THREE.EdgesGeometry(objectCube.geometry);
                const objLine = new THREE.LineSegments(objEdges, new THREE.LineBasicMaterial({ color: 0x7c2d12 }));
                objectCube.add(objLine);

                // ระดับน้ำ Y = 2.45
                const waterSurfaceY = 2.45;
                
                if (isFloating) {
                    targetY = waterSurfaceY - h_sub + (L / 2);
                } else {
                    // หากจม จะแขวนเชือกค้างไว้กลางน้ำ 
                    targetY = 1.2;
                }

                // --- ควบคุมแผนภาพเวกเตอร์ (Force Diagrams) ---
                const baseLen = 1.8; // ความยาวพื้นฐานที่สวยงามสำหรับหน้าจอ
                const lenW = baseLen;
                const lenFb = baseLen * (displacedMass / M_obj);
                const lenWapp = baseLen * (scaleReadingMass / M_obj);
                const offset = (L / 2) + 0.2; // ระยะห่างจากศูนย์กลาง

                arrowW.position.set(0, 0, 0);
                arrowFb.position.set(-offset, 0, 0);
                arrowWapp.position.set(offset, 0, 0);

                // อัปเดตความยาวเวกเตอร์
                arrowW.setLength(lenW, 0.2, 0.15);
                if (lenFb > 0.05) {
                    arrowFb.visible = true;
                    arrowFb.setLength(lenFb, 0.2, 0.15);
                } else { arrowFb.visible = false; }
                
                if (lenWapp > 0.05) {
                    arrowWapp.visible = true;
                    arrowWapp.setLength(lenWapp, 0.2, 0.15);
                } else { arrowWapp.visible = false; }

                // คำนวณแรงเป็นนิวตัน (Force in Newtons)
                const W_force = M_obj * 9.81;
                const Fb_force = displacedMass * 9.81;
                const Wapp_force = scaleReadingMass * 9.81;

                // อัปเดตป้ายตัวหนังสือให้เป็นหน่วย N (Newtons)
                updateForceLabel(labelW, `W = ${W_force.toFixed(1)} N`);
                updateForceLabel(labelFb, `Fb = ${Fb_force.toFixed(1)} N`);
                updateForceLabel(labelWapp, `Wapp = ${Wapp_force.toFixed(1)} N`);

                // จัดตำแหน่งป้ายให้อยู่ปลายลูกศร และขยับออกห่างขึ้นอีกเล็กน้อยไม่ให้ทับวัตถุ
                labelW.position.set(0.9, -lenW / 2, 0);
                labelFb.position.set(-offset - 1.1, lenFb / 2, 0);
                labelWapp.position.set(offset + 1.1, lenWapp / 2, 0);
            }

            // อัปเดตตัวเลขหน้าตาชั่ง (ตาชั่งปกติยังคงแสดงมวลเป็น kg)
            updateScaleSpriteText(scaleSprite, scaleReadingMass.toFixed(2) + " kg");

            // --- อัปเดตแผงแสดงวิธีคำนวณอย่างละเอียด (Detailed HUD) ---
            const calcHTML = `
                <div class="space-y-5">
                    <div>
                        <span class="font-bold text-sky-300 text-[15px]">${getT('calc_step1')}</span><br>
                        \\(V_{obj} = L^3 = ${L.toFixed(2)}^3 = ${V_obj.toFixed(4)} \\ m^3\\)<br>
                        \\(M_{obj} = \\rho_{obj} \\cdot V_{obj} = ${rho_obj} \\times ${V_obj.toFixed(4)} = ${M_obj.toFixed(2)} \\ kg\\)
                    </div>
                    <div>
                        <span class="font-bold text-sky-300 text-[15px]">${getT('calc_step2')}</span><br>
                        <span class="text-slate-300 italic">${isFloating ? getT('calc_float') : getT('calc_sink')}</span><br>
                        \\(V_{sub} = ${V_sub.toFixed(4)} \\ m^3\\)<br>
                        <span class="text-emerald-300">\\(h_{sub} = \\frac{V_{sub}}{L^2} = \\frac{${V_sub.toFixed(4)}}{${A_base.toFixed(4)}} = ${h_sub.toFixed(3)} \\ m\\)</span>
                    </div>
                    <div>
                        <span class="font-bold text-sky-300 text-[15px]">${getT('calc_step3')}</span><br>
                        \\(M_{disp} = \\rho_{fluid} \\cdot V_{sub} = ${rho_fluid} \\times ${V_sub.toFixed(4)} = ${displacedMass.toFixed(2)} \\ kg\\)<br>
                        \\(F_b = M_{disp} \\cdot g = ${displacedMass.toFixed(2)} \\times 9.81 = ${Fb.toFixed(2)} \\ N\\)
                    </div>
                    <div class="border-t border-slate-600 pt-3">
                        <span class="font-bold text-sky-300 text-[15px]">${getT('calc_step4')}</span><br>
                        \\(M_{app} = M_{obj} - M_{disp} = ${M_obj.toFixed(2)} - ${displacedMass.toFixed(2)}\\)<br>
                        <div class="text-emerald-400 font-bold text-[18px] mt-2 bg-slate-900 inline-block px-4 py-1.5 rounded-lg border border-slate-600">Scale = ${scaleReadingMass.toFixed(2)} kg</div>
                    </div>
                </div>
            `;
            
            document.getElementById('sim-calc-hud').innerHTML = calcHTML;
            // ประมวลผลสมการ LaTeX ใน Panel ใหม่
            if(window.MathJax) MathJax.typesetPromise([document.getElementById('sim-calc-hud')]);
        }

        // จับตาดูเมื่อมีการเลื่อน Slider
        objDensityInput.addEventListener('input', updateSimulationMath);
        fluidDensityInput.addEventListener('input', updateSimulationMath);
        objLengthInput.addEventListener('input', updateSimulationMath);

        // การควบคุมการเคลื่อนไหว Animation (Render Loop)
        function animate() {
            requestAnimationFrame(animate);
            
            if(objectCube) {
                // แอนิเมชันให้วัตถุลอยกระเพื่อมเบาๆ 
                if (isFloating) {
                    time += 0.04;
                    const bob = Math.sin(time) * 0.03;
                    objectCube.position.y += ((targetY + bob) - objectCube.position.y) * 0.1;
                } else {
                    objectCube.position.y += (targetY - objectCube.position.y) * 0.15;
                }

                // อัปเดตความยาวเชือก/ลวด ให้เชื่อมต่อกันแบบ Dynamic
                if (wireLine) {
                    const L = parseFloat(objLengthInput.value);
                    const positions = wireLine.geometry.attributes.position.array;
                    positions[1] = 4.05; // ด้านบนของเชือกติดกับขอเกี่ยวตาชั่ง (Y=4.05)
                    positions[4] = objectCube.position.y + (L / 2); // ด้านล่างผูกกับบนสุดของวัตถุ
                    wireLine.geometry.attributes.position.needsUpdate = true;
                    
                    // ถ้ายกขึ้นมา (ลอย) เชือกจะหย่อนเป็นสีเทา ถ้าโดนดึงตึง (จม) เชือกจะเป็นสีเข้ม
                    wireLine.material.color.setHex(isFloating ? 0x94a3b8 : 0x1e293b);
                }
            }

            renderer.render(scene, camera);
        }

        // --- 3. การคำนวณโจทย์ตัวอย่าง (Interactive Examples) ---
        const g = 9.81;

        // คำนวณและแสดงวิธีทำโจทย์ข้อ 1
        function calculateEx1() {
            const v = parseFloat(document.getElementById('ex1-v').value) || 0;
            const rho = parseFloat(document.getElementById('ex1-rho').value) || 0;
            const fb = rho * v * g;

            const html = `
                <div class="solution-step">
                    ${getT('step_given')}<br>
                    \\(V_{sub} = ${v} \\ m^3\\) <br>
                    \\(\\rho = ${rho} \\ kg/m^3\\) <br>
                    \\(g = 9.81 \\ m/s^2\\)
                </div>
                <div class="solution-step">
                    ${getT('step_formula')}<br>
                    \\[ F_b = \\rho \\cdot V_{sub} \\cdot g \\]
                </div>
                <div class="solution-step bg-sky-50 border-sky-400">
                    ${getT('step_sub')}<br>
                    \\[ F_b = ${rho} \\times ${v} \\times 9.81 = ${fb.toFixed(2)} \\ N \\]
                    <div class="text-sky-700 font-bold mt-2">✨ ${getT('ans_text')} ${fb.toFixed(2)} N.</div>
                </div>
            `;

            document.getElementById('ex1-steps').innerHTML = html;
            if(window.MathJax) MathJax.typesetPromise([document.getElementById('ex1-steps')]).catch(err => console.log(err));
        }

        // คำนวณและแสดงวิธีทำโจทย์ข้อ 2
        function calculateEx2() {
            const m = parseFloat(document.getElementById('ex2-m').value) || 0;
            const v = parseFloat(document.getElementById('ex2-v').value) || 0;
            const rho = parseFloat(document.getElementById('ex2-rho').value) || 0;
            
            const weight = m * g;
            const fb = rho * v * g;
            const apparentW = weight - fb;
            let finalRes = apparentW < 0 ? 0 : apparentW; 
            
            const html = `
                <div class="solution-step">
                    ${getT('step2_w')}<br>
                    \\[ W = m \\cdot g = ${m} \\times 9.81 = ${weight.toFixed(2)} \\ N \\]
                </div>
                <div class="solution-step">
                    ${getT('step2_fb')}<br>
                    \\[ F_b = \\rho \\cdot V \\cdot g = ${rho} \\times ${v} \\times 9.81 = ${fb.toFixed(2)} \\ N \\]
                </div>
                <div class="solution-step bg-orange-50 border-orange-400">
                    ${getT('step2_app')}<br>
                    \\[ W_{app} = W - F_b \\]<br>
                    \\[ W_{app} = ${weight.toFixed(2)} - ${fb.toFixed(2)} = ${apparentW.toFixed(2)} \\ N \\]
                    <div class="text-orange-700 font-bold mt-2">✨ ${getT('ans_app')} ${finalRes.toFixed(2)} N.</div>
                </div>
            `;

            document.getElementById('ex2-steps').innerHTML = html;
            if(window.MathJax) MathJax.typesetPromise([document.getElementById('ex2-steps')]).catch(err => console.log(err));
        }

        // ---------------- เริ่มทำงานเมื่อโหลดหน้าเว็บ ----------------
        window.onload = function() {
            init3D();
            
            // รอดีเลย์สั้นๆ เพื่อให้มั่นใจว่า Fonts และไลบรารีต่างๆ พร้อมทำงาน
            setTimeout(() => {
                updateSimulationMath();
                calculateEx1();
                calculateEx2();
                if(window.MathJax) MathJax.typesetPromise();
            }, 100);
        };
    </script>
